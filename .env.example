# Copy to .env and adjust. Never commit .env.

# Single-user bearer token. Change to a long random string.
KOMPASS_TOKEN=change-me-please

# SQLite for dev. For prod use e.g.
#   postgresql+psycopg://user:pass@db:5432/kompass
DATABASE_URL=sqlite:////data/kompass.db

# CORS allow-list (comma-separated). Default covers Vite dev server.
CORS_ORIGINS=http://localhost:5173

# The backend URL the frontend calls. For docker compose: http://localhost:8000
VITE_API_BASE=http://localhost:8000
